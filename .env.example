# Supabase — obtén estos valores en https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry — obtén el DSN en https://sentry.io → tu proyecto → Settings → Client Keys (DSN)
# Si se deja vacío, Sentry no se inicializa (la app sigue funcionando)
VITE_SENTRY_DSN=
